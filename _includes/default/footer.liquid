<footer class="site-footer">
    <p class="text">
        {{ site.footer_text | default: "Copyright" }} {{ site.time | date: '%Y' }}
    </p>

    {% if site.legal.kvk != "" or site.legal.vat != "" or site.legal.insurance != "" %}
    <p class="text footer-legal">
      {%- if site.legal.entity %}{{ site.legal.entity }}{%- endif -%}
      {%- if site.legal.kvk != "" %} · KvK {{ site.legal.kvk }}{%- endif -%}
      {%- if site.legal.vat != "" %} · BTW {{ site.legal.vat }}{%- endif -%}
      {%- if site.legal.insurance != "" %} · {{ site.legal.insurance }}{%- endif -%}
    </p>
    {% endif %}

    <div class="footer-icons">
        <ul>
            {% include social/icons.liquid %}
        </ul>
    </div>

    {% if site.mermaid %}
        <script type="module">
          mermaid.initialize({ startOnLoad: false, theme: "default" });
          mermaid.run({ nodes: [...document.querySelectorAll('.language-mermaid'), ...document.querySelectorAll('.mermaid')] });
        </script>
    {% endif %}
</footer>
