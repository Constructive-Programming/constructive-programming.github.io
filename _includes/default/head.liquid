{% comment %}
  Local override of Type-on-Strap's head.liquid.

  Differences from upstream:
  - Drops jQuery, Popper, Bootstrap-JS, Bootstrap-CSS. Layout, grid,
    cards, buttons, type scale are now driven by our own CSS in
    assets/css/main.scss.
  - The mobile nav toggle no longer needs main.min.js's jQuery — a
    small vanilla-JS handler lives in navbar.liquid.
  - Theme JS (main.min.js) kept for KaTeX init + theme-toggle, which
    do not use jQuery.
  - Proper favicon set, RSS auto-discovery, and twitter:image meta.
{% endcomment %}

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, minimum-scale=0.5, maximum-scale=5">

    <!-- Theme Mode -->
    <script>
        const darkBtn = "{{ site.data.language.str_dark | default: "Dark" }}";
        const lightBtn = "{{ site.data.language.str_light | default: "Light" }}";
        const isAutoTheme = {% if site.color_theme == 'auto' %}true{% else %}false{% endif %};
        const preferredTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        if (isAutoTheme) {
            document.documentElement.setAttribute('data-theme', sessionStorage.getItem('theme') ?? preferredTheme);
        } else {
            document.documentElement.setAttribute('data-theme', "{{ site.color_theme | default: 'light' }}");
        }
    </script>

    <!-- Globals consumed by main.min.js. We don't use the cookie/GA
         features but the script references these variables unguarded;
         declaring them as empty strings makes main.min.js no-op those
         branches and still attach its DOMContentLoaded listeners. -->
    <script>
      const cookieName = 'cookie-notice-dismissed-{{ site.url }}';
      const isCookieConsent = '{{ site.cookie_consent }}';
      const analyticsName = '{{ site.google_analytics }}';
      const analyticsNameGA4 = '{{ site.google_analytics_ga4 }}';
    </script>

    <!-- Theme JS — KaTeX init + theme-toggle + navbar toggle. -->
    <script defer src="{{ '/assets/js/main.min.js' | relative_url }}"></script>

    <!-- Local stylesheet — drives everything: type scale, layout, grid,
         cards, buttons. No external CSS framework. -->
    <link rel="stylesheet" href="{{ '/assets/css/main.css' | relative_url }}">

    <!-- Favicon set — SVG primary, ICO fallback, apple-touch for iOS. -->
    <link rel="icon" type="image/svg+xml" href="{{ '/assets/img/favicon.svg' | relative_url }}">
    <link rel="alternate icon" type="image/x-icon" href="{{ '/assets/img/favicon.ico' | relative_url }}">
    <link rel="apple-touch-icon" sizes="180x180" href="{{ '/assets/img/apple-touch-icon.png' | relative_url }}">

    <!-- RSS auto-discovery -->
    <link rel="alternate" type="application/rss+xml" title="{{ site.title }}" href="{{ '/feed.xml' | absolute_url }}">

    <!-- KaTeX 0.16.38 -->
    {% if site.katex or site.theme_settings.katex %}
    <script defer src="{{ '/assets/js/vendor/katex.min.js' | relative_url }}"></script>
    <script defer src="{{ '/assets/js/vendor/katex.auto-render.min.js' | relative_url }}" onload="renderMathInElement(document.body);"></script>
    {% endif %}

    <!-- Mermaid 11.13.0 -->
    {% if site.mermaid %}
    <script defer src="{{ '/assets/js/vendor/mermaid.min.js' | relative_url }}"></script>
    {% endif %}

    <!-- Simple-Jekyll-Search 2.1.3 -->
    <script src="{{ '/assets/js/vendor/simple-jekyll-search.min.js' | relative_url }}" type="text/javascript"></script>

    <!-- Open Graph + Twitter -->
    {% assign og_img = '/assets/img/og-image.png' | absolute_url %}
    {% if page.thumbnail %}
      {% assign og_img = page.thumbnail | absolute_url %}
    {% elsif page.feature-img %}
      {% assign og_img = page.feature-img | absolute_url %}
    {% endif %}
    <meta property="og:image" content="{{ og_img }}">
    <meta name="twitter:image" content="{{ og_img }}">
    <meta name="twitter:card" content="summary_large_image">
    {% unless page.layout == post %}
    <meta property="og:type" content="website" />
    {% endunless %}
    {% seo %}
</head>
