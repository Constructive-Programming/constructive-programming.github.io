{% comment %}
  Local override of Type-on-Strap's navbar.

  Differences from upstream:
  - Skip pages whose URL points at the theme author.
  - Replace the Font Awesome <i class="fas fa-bars"> hamburger with
    an inline SVG (no FA dependency for the toggle).
  - Drop the page.icon FA decoration for Search / Tags — text labels
    only. The theme's bundled main.min.js handles the toggle via
    vanilla JS (toggles `.hide` on the nav ul), so no jQuery needed.
{% endcomment %}

<header class="site-header">

    <!-- Logo and title -->
    <div class="branding">
        {% if site.avatar %}
        <a href="{{ '/' | relative_url }}">
            <img alt="logo img" class="avatar" src="{{ site.avatar | relative_url }}" loading="lazy"/>
        </a>
        {% endif %}
        <a class="site-title" aria-label="{{ site.title }}" href="{{ '/' | relative_url }}">
        {{ site.title }}
        </a>
    </div>

    <!-- Toggle menu -->
    <nav class="clear">
    <a aria-label="Open menu" id="pull" class="toggle" href="#">
        <svg class="cp-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <rect x="4" y="6"  width="16" height="2" rx="1"/>
            <rect x="4" y="11" width="16" height="2" rx="1"/>
            <rect x="4" y="16" width="16" height="2" rx="1"/>
        </svg>
    </a>

    <!-- Menu -->
    <ul class="hide">
        {% assign name_page = "" %}
        {% assign emptyArray = '' | split: '' %}
        {% assign menus = site.data.menu | default: emptyArray %}
        {% assign pages = site.pages | concat: menus | sort: 'position' %}
        {% for page in pages %}
        {% assign external = false %}
        {% if page.url contains 'sylhare' or page.url contains 'Type-on-Strap' %}{% assign external = true %}{% endif %}
        {% unless page.title == null or page.hide or external or name_page contains page.title %}
            <li class="separator"> | </li>
            <li>
                <a class="clear" aria-label="{{ page.title }}" title="{{ page.title }}" href="{{ page.url | relative_url }}">
                    <span class="navbar-label">{{ page.title }}</span>
                </a>
            </li>
        {% endunless %}
        {% assign name_page = page.title | append: name_page %}
        {% endfor %}

        {% if site.color_theme == 'auto' %}
        <li class="separator"> | </li>
        <li><a id="theme-toggle" title="{{ site.data.language.str_dark | default: 'Toggle theme' }}" aria-label="{{ site.data.language.str_dark | default: 'Toggle theme' }}" onclick="themeToggle()"></a></li>
        {% endif %}
    </ul>

    </nav>
</header>
