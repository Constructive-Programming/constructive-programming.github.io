{% comment %}
  Local override of Type-on-Strap's category_list.liquid.
  Drops the Font Awesome <i class="fas fa-folder"> icon — purely
  decorative; the "Category/Categories" label already names the list.
{% endcomment %}
{% assign categories = include.categories | split:'|' | sort | uniq %}

{% if categories.size > 0 %}
  <div class="category-list" data-testid="category-list">
    <ul>
      {% if categories.size == 1 %}
        <li class="meta">Category</li>
      {% else %}
        <li class="meta">Categories</li>
      {% endif %}

      {% for category in categories %}
        <li><a class="button" data-testid="category-link" href="{{ site.baseurl }}/categories#{{ category | cgi_escape }}">
          <p>{{ category }}</p>
        </a></li>
      {% endfor %}
    </ul>
  </div>
{% else %}
  <div class="category-list"></div>
{% endif %}
